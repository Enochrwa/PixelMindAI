# ============================================================
# PixelMind AI — Backend Environment Variables
# Copy this file to .env and fill in real values.
# This same .env is used whether you run the backend directly
# (uvicorn) or via Docker Compose — both read backend/.env.
# ============================================================

# App
SECRET_KEY=your-super-secret-key-min-32-characters-here
ENVIRONMENT=development
DEBUG=true

# Database (Aiven PostgreSQL)
# Get this from the Aiven console -> your service -> "Connection information"
# Must keep ?ssl=require (Aiven requires TLS).
DATABASE_URL=postgresql+asyncpg://avnadmin:xxx@pg-xxx.aivencloud.com:18957/PIXELMINDAI?ssl=require
# Aiven doesn't run a separate pgbouncer endpoint by default, so this can be
# the same URL as DATABASE_URL unless you've set up Aiven's connection pooling.
DATABASE_URL_POOLED=postgresql+asyncpg://avnadmin:xxx@pg-xxx.aivencloud.com:18957/PIXELMINDAI?ssl=require

# Redis (Upstash)
# Use the "Redis" / TCP connection string from the Upstash console
# (NOT the REST URL/token — those are for the HTTP REST API client only).
# Format: rediss://default:<password>@<host>:6379
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Upstash REST credentials (optional — not used by the current arq/redis.asyncio
# code, kept here in case a future feature needs the HTTP REST client)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare R2 (optional — file storage; leave blank to disable)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pixelmind-uploads
R2_PUBLIC_URL=

# Groq AI (optional — free tier: 14,400 req/day; leave blank to disable)
GROQ_API_KEY=

# Email — Resend (optional, 100/day free cap; leave blank to disable)
RESEND_API_KEY=

# Email — Brevo (optional fallback, 300/day free; leave blank to disable)
BREVO_API_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://pixelmind.vercel.app
