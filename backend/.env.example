# ============================================================
# PixelMind AI — Backend Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# App
SECRET_KEY=your-super-secret-key-min-32-characters-here
ENVIRONMENT=development
DEBUG=true

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/pixelmind
DATABASE_URL_POOLED=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/pixelmind?pgbouncer=true

# Redis (Upstash)
REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=pixelmind-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Groq AI (free tier: 14,400 req/day)
GROQ_API_KEY=gsk_xxx

# Email — Resend (primary, 100/day free cap)
RESEND_API_KEY=re_xxx

# Email — Brevo (fallback, 300/day free)
BREVO_API_KEY=xkeysib-xxx

# Sentry (optional — 5K errors/month free)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://pixelmind.vercel.app
